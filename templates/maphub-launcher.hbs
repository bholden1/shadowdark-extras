            </div>
            <div class="generator-actions">
                <button class="open-generator" data-action="open-dungeon">Open</button>
            </div>
        </div>

        <div class="generator-card" data-generator="dwellings">
            <div class="generator-icon"><i class="fas fa-building"></i></div>
            <div class="generator-info">
                <h3>Dwelling Generator</h3>
                <p>Generate floorplans for individual houses, taverns, and manors, with walls.</p>
            </div>
            <div class="generator-actions">
                <button class="open-generator" data-action="open-dwellings">Open</button>
            </div>
        </div>
    </div>

